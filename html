        { id: 42, text: "Compared with the coil-to-coil rolling mode, ________.", options: ["semi-endless mode requires lower casting speed", "the main advantage of the semi-endless rolling mode is less crop loss at the head and tail of the strip, and lower material loss", "semi-endless mode can produce medium-thick plates more easily", "semi-endless mode has a more simplified mill structure"], type: "single", answer: "the main advantage of the semi-endless rolling mode is less crop loss at the head and tail of the strip, and lower material loss", explanation: "Compared with... coil-to-coil ➔ the main advantage of the semi-endless rolling mode is less crop loss at the head and tail of the strip, and lower material loss" },
        { id: 43, text: "The TSP process takes the ________ as the core equipment, focusing on low-cost compact production.", options: ["planetary mill", "Steckel mill (reversing coiling mill)", "twin-roll caster", "three-roll caster"], type: "single", answer: "Steckel mill (reversing coiling mill)", explanation: "TSP / low-cost compact ➔ Steckel mill (reversing coiling mill)" },
        { id: 44, text: "The CSP process was developed by the SMS group of Germany, and its core buffer equipment is the ________.", options: ["Coilbox", "CremonaBox", "tunnel furnace", "induction heating furnace"], type: "single", answer: "tunnel furnace", explanation: "CSP / SMS group ➔ tunnel furnace" },
        { id: 45, text: "The signature equipment that distinguishes the ISP process from CSP is the ________ and the induction heating device.", options: ["Coilbox", "CremonaBox", "tunnel furnace", "laminar cooling"], type: "single", answer: "CremonaBox", explanation: "ISP / distinguishes... from CSP ➔ CremonaBox" },
        { id: 46, text: "The core advantage of the fTSR (flexible Thin Slab Rolling) process is ________.", options: ["compatibility with both thin slabs and medium-thick slabs, adapting to multi-specification and multi-grade production", "lowest energy consumption in the industry", "zero scale formation", "mass production of a single product"], type: "single", answer: "compatibility with both thin slabs and medium-thick slabs, adapting to multi-specification and multi-grade production", explanation: "fTSR / core advantage ➔ compatibility with both thin slabs and medium-thick slabs, adapting to multi-specification and multi-grade production" },
        { id: 47, text: "The ISP process production line is extremely compact, with the shortest length of only ________, which is much shorter than the CSP line.", options: ["80m", "180m", "380m", "580m"], type: "single", answer: "180m", explanation: "ISP / extremely compact / shortest length ➔ 180m" },
        { id: 48, text: "ESP is the ________ production process, which can achieve uninterrupted continuous rolling throughout the process.", options: ["coil-to-coil", "semi-endless", "endless strip", "batch plate"], type: "single", answer: "endless strip", explanation: "ESP / uninterrupted continuous rolling ➔ endless strip" },
        { id: 49, text: "The ESP process adopts ________ to rapidly compensate for the temperature drop of the slab, with high temperature control precision.", options: ["walking-beam furnace", "induction heating furnace", "gas-fired furnace", "bell-type annealing furnace"], type: "single", answer: "induction heating furnace", explanation: "ESP / compensate for the temperature drop ➔ induction heating furnace" },
        { id: 50, text: "The DUE process adopts ________ to achieve temperature-controlled rolling, which is used to produce pipeline steel and low-temperature high-strength steel.", options: ["natural air cooling", "ultrafast cooling system", "hot water spray system", "protective gas cooling"], type: "single", answer: "ultrafast cooling system", explanation: "DUE / pipeline steel ➔ ultrafast cooling system" }
    ];

    // ---------- 核心逻辑：严格重复控制（前后5次测试，任意两组重复题目≤2道）----------
    let currentQuestions = [];
    let currentQIndex = 0;
    let userScores = [];
    let waitingAutoNext = false;
    let isAnswered = false;
    let historySets = [];
    const MAX_HISTORY = 5;
    const QUESTIONS_PER_SET = 10;
    let darkMode = localStorage.getItem('darkMode') === 'true';
    const quizContainer = document.getElementById('quizContainer');
    const newSetBtn = document.getElementById('newSetBtn');
    const darkModeBtn = document.getElementById('darkModeBtn');
    const resetHistoryBtn = document.getElementById('resetHistoryBtn');
    const bankSizeSpan = document.getElementById('bankSize');
    const historyStatusSpan = document.getElementById('historyStatus');

    function updateBankSize() { bankSizeSpan.innerText = QUESTION_BANK.length; }

    function persistHistory() {
        localStorage.setItem('quizHistory', JSON.stringify(historySets.map(s => Array.from(s))));
    }

    function loadHistory() {
        const stored = localStorage.getItem('quizHistory');
        if (stored) try {
            historySets = JSON.parse(stored).map(arr => new Set(arr));
            while (historySets.length > MAX_HISTORY) historySets.shift();
        } catch (e) { historySets = []; }
        else historySets = [];
        updateHistoryStatusText();
    }

    function updateHistoryStatusText() {
        historyStatusSpan.innerHTML = historySets.length ? `📋 历史套数: ${historySets.length}/5` : `📋 历史套数: 无`;
    }

    function isAcceptableSet(selectedIds) {
        if (historySets.length === 0) return true;
        const newSet = new Set(selectedIds);
        for (let histSet of historySets) {
            let overlap = 0;
            for (let id of newSet) {
                if (histSet.has(id)) overlap++;
                if (overlap > 2) return false;
            }
        }
        return true;
    }

    function selectQuestionsWithConstraint() {
        let shuffled = [...QUESTION_BANK];
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }

        for (let attempt = 0; attempt < 150; attempt++) {
            let candidate = [];
            let usedIds = new Set();
            for (let q of shuffled) {
                if (candidate.length >= QUESTIONS_PER_SET) break;
                if (!usedIds.has(q.id)) {
                    candidate.push(q);
                    usedIds.add(q.id);
                }
            }
            if (candidate.length < QUESTIONS_PER_SET) continue;
            const candidateIds = candidate.map(q => q.id);
            if (isAcceptableSet(candidateIds)) {
                for (let i = candidate.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [candidate[i], candidate[j]] = [candidate[j], candidate[i]];
                }
                return candidate.slice(0, QUESTIONS_PER_SET);
            }
        }

        for (let attempt = 0; attempt < 50; attempt++) {
            let candidate = [];
            let usedIds = new Set();
            for (let q of shuffled) {
                if (candidate.length >= QUESTIONS_PER_SET) break;
                if (!usedIds.has(q.id)) {
                    candidate.push(q);
                    usedIds.add(q.id);
                }
            }
            if (candidate.length < QUESTIONS_PER_SET) continue;
            let ok = true;
            const candSet = new Set(candidate.map(q => q.id));
            for (let histSet of historySets) {
                let overlap = 0;
                for (let id of candSet) if (histSet.has(id)) overlap++;
                if (overlap > 3) { ok = false; break; }
            }
            if (ok) {
                for (let i = candidate.length - 1; i > 0; i--) {
                    const j = Math.floor(Math.random() * (i + 1));
                    [candidate[i], candidate[j]] = [candidate[j], candidate[i]];
                }
                return candidate.slice(0, QUESTIONS_PER_SET);
            }
        }

        let fallback = [];
        let seen = new Set();
        for (let q of QUESTION_BANK) {
            if (fallback.length >= QUESTIONS_PER_SET) break;
            if (!seen.has(q.id)) { fallback.push(q); seen.add(q.id); }
        }
        return fallback;
    }

    function addToHistory(questions) {
        let idset = new Set(questions.map(q => q.id));
        historySets.push(idset);
        while (historySets.length > MAX_HISTORY) historySets.shift();
        persistHistory();
        updateHistoryStatusText();
    }

    function renderQuestion() {
        if (currentQIndex >= currentQuestions.length) {
            renderSummary();
            return;
        }
        const q = currentQuestions[currentQIndex];
        isAnswered = false;

        let optionsHtml = '';
        const letters = ['A', 'B', 'C', 'D', 'E', 'F'];
        q.options.forEach((opt, idx) => {
            const letter = letters[idx] || String.fromCharCode(65 + idx);
            optionsHtml += `
                <div class="option" data-idx="${idx}">
                    <input type="${q.type === 'multi' ? 'checkbox' : 'radio'}" name="q${q.id}" id="q${q.id}_opt${idx}" value="${idx}">
                    <label for="q${q.id}_opt${idx}">${letter}. ${opt}</label>
                </div>
            `;
        });

        const typeBadge = q.type === 'multi'
            ? '<span class="type-badge">多选题（点击「提交本题」判题）</span>'
            : '<span class="type-badge">单选题（点击选项自动判题）</span>';

        quizContainer.innerHTML = `
            <div class="quiz-card">
                <div class="progress">📍 进度 ${currentQIndex + 1}/${currentQuestions.length} ${typeBadge}</div>
                <div class="question-text">${q.text}</div>
                <div class="options-area" id="optionsArea">
                    ${optionsHtml}
                </div>
                <div class="feedback-area" id="feedbackArea"></div>
                <div class="action-buttons">
                    ${q.type === 'multi' ? '<button class="btn-submit" id="submitBtn">提交本题</button>' : ''}
                    <button class="btn-next" id="nextBtn">下一题 ➡️</button>
                </div>
            </div>
        `;

        const optionsArea = document.getElementById('optionsArea');
        const feedbackArea = document.getElementById('feedbackArea');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');

        if (q.type === 'single') {
            optionsArea.querySelectorAll('.option').forEach(opt => {
                opt.addEventListener('click', () => {
                    if (isAnswered) return;
                    const idx = parseInt(opt.dataset.idx);
                    checkSingleAnswer(idx);
                });
            });
        } else if (q.type === 'multi') {
            submitBtn.addEventListener('click', checkMultiAnswer);
        }

        nextBtn.addEventListener('click', () => {
            currentQIndex++;
            renderQuestion();
        });
    }

    function checkSingleAnswer(selectedIdx) {
        const q = currentQuestions[currentQIndex];
        isAnswered = true;
        const selectedText = q.options[selectedIdx];
        const isCorrect = selectedText === q.answer;

        const optionsArea = document.getElementById('optionsArea');
        const feedbackArea = document.getElementById('feedbackArea');
        const nextBtn = document.getElementById('nextBtn');

        optionsArea.classList.add('disabled-options');

        if (isCorrect) {
            userScores[currentQIndex] = true;
            feedbackArea.className = 'feedback-area show feedback-correct';
            feedbackArea.innerHTML = `
                ✔️ <strong>回答正确</strong><br>
                📖 ${q.explanation}
            `;
            setTimeout(() => {
                currentQIndex++;
                renderQuestion();
            }, 1200);
        } else {
            userScores[currentQIndex] = false;
            feedbackArea.className = 'feedback-area show feedback-wrong';
            let correctIdx = q.options.indexOf(q.answer);
            feedbackArea.innerHTML = `
                ❌ <strong>回答错误</strong><br>
                ✔️ 正确选项: ${q.answer}<br>
                📖 ${q.explanation}
            `;
            nextBtn.classList.add('show');
        }
    }

    function checkMultiAnswer() {
        const q = currentQuestions[currentQIndex];
        if (isAnswered) return;
        isAnswered = true;

        const optionsArea = document.getElementById('optionsArea');
        const feedbackArea = document.getElementById('feedbackArea');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');

        const checked = Array.from(optionsArea.querySelectorAll('input[type="checkbox"]:checked'))
            .map(cb => parseInt(cb.value));
        const correctAnswers = q.answer;
        const correctIndices = q.options
            .map((opt, idx) => correctAnswers.includes(opt) ? idx : -1)
            .filter(i => i >= 0);

        const selectedSet = new Set(checked);
        const correctSet = new Set(correctIndices);
        const isCorrect = selectedSet.size === correctSet.size &&
            [...selectedSet].every(s => correctSet.has(s));

        optionsArea.classList.add('disabled-options');
        submitBtn.style.display = 'none';

        if (isCorrect) {
            userScores[currentQIndex] = true;
            feedbackArea.className = 'feedback-area show feedback-correct';
            feedbackArea.innerHTML = `
                ✔️ <strong>回答正确</strong><br>
                📖 ${q.explanation}
            `;
            setTimeout(() => {
                currentQIndex++;
                renderQuestion();
            }, 1200);
        } else {
            userScores[currentQIndex] = false;
            feedbackArea.className = 'feedback-area show feedback-wrong';
            feedbackArea.innerHTML = `
                ❌ <strong>回答错误</strong><br>
                ✔️ 正确答案: ${correctAnswers.join('、')}<br>
                📖 ${q.explanation}
            `;
            nextBtn.classList.add('show');
        }
    }

    function renderSummary() {
        const correct = userScores.filter(s => s).length;
        const total = currentQuestions.length;
        const percent = Math.round(correct / total * 100);

        quizContainer.innerHTML = `
            <div class="quiz-card score-summary">
                <div class="final-score">🎉 本组完成！</div>
                <div style="font-size: 2rem; font-weight: 700; margin: 1rem 0; color: var(--accent);">
                    ${correct} / ${total} 分
                </div>
                <div style="color: var(--text-secondary); margin-bottom: 1.5rem;">
                    正确率: ${percent}%
                </div>
                <button class="primary" onclick="startNewSet()">✨ 再来一组</button>
            </div>
        `;
    }

    function startNewSet() {
        currentQuestions = selectQuestionsWithConstraint();
        currentQIndex = 0;
        userScores = new Array(currentQuestions.length).fill(false);
        addToHistory(currentQuestions);
        renderQuestion();
    }

    function toggleDarkMode() {
        darkMode = !darkMode;
        document.body.classList.toggle('dark', darkMode);
        localStorage.setItem('darkMode', darkMode);
    }

    function resetHistory() {
        if (confirm('确定要重置所有历史记录吗？这将清除重复控制的记忆。')) {
            historySets = [];
            localStorage.removeItem('quizHistory');
            updateHistoryStatusText();
            alert('历史记录已重置');
        }
    }

    // 初始化
    updateBankSize();
    loadHistory();
    if (darkMode) document.body.classList.add('dark');

    newSetBtn.addEventListener('click', startNewSet);
    darkModeBtn.addEventListener('click', toggleDarkMode);
    resetHistoryBtn.addEventListener('click', resetHistory);

    // 自动开始第一组
    startNewSet();
</script>
